{
  "name": "Magento 2 Interview",

  "dockerComposeFile": "../docker-compose.yml",

  "service": "app",

  "workspaceFolder": "/var/www/html",

  "forwardPorts": [8080],

  "postCreateCommand": "bash /workspaces/magento2-interview/setup.sh 2>&1 | tee /tmp/magento-setup.log",

  "customizations": {
    "vscode": {
      "extensions": [
        "bmewburn.vscode-intelephense-client",
        "xdebug.php-debug",
        "esbenp.prettier-vscode"
      ]
    }
  }
}
